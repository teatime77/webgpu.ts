{
    "name": "surface",
    "version": "1.0",
    "metadata": {
        "gridWidth": 100,
        "gridHeight": 100,
        "time": 0.0
    },
    "resources": {
        "Params": {
            "type": "uniform",
            "fields": {
                "gridWidth": "f32",
                "gridHeight": "f32",
                "time": "f32"
            }
        },
        "Camera": {
            "type": "uniform",
            "fields": {
                "viewProjection": "mat4x4<f32>",
                "view": "mat4x4<f32>"
            }
        },
        "SurfaceData": {
            "type": "storage",
            "access": "read_write",
            "format": "vec4<f32>",
            "count": "$metadata.gridWidth * $metadata.gridHeight * 2" 
        }
    },
    "nodes": [
        {
            "id": "compute_surface",
            "type": "compute",
            "shader": "compute_surface",
            "dispatch": {
                "type": "direct",
                "workgroups": ["$metadata.gridWidth / 8 + 1", "$metadata.gridHeight / 8 + 1", 1]
            },
            "bindings": [
                { "binding": 0, "resource": "Params" },
                { "binding": 1, "resource": "SurfaceData" }
            ]
        },
        {
            "id": "render_surface",
            "type": "render",
            "shader": "render_surface",
            "topology": "triangle-list",
            "depthTest": true,
            "draw": {
                "type": "direct",
                "vertexCount": "($metadata.gridWidth - 1) * ($metadata.gridHeight - 1) * 6"
            },
            "bindings": [
                { "binding": 0, "resource": "Params" },
                { "binding": 1, "resource": "Camera" },
                { "binding": 2, "resource": "SurfaceData", "access": "read" }
            ]
        }
    ]
}