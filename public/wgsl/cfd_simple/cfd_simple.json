{
  "name": "cfd_simple",
  "version": "1.0",
  "uis": [
    {
      "name": "dt",
      "label": "Time Step",
      "min": 0.005,
      "max": 0.08,
      "step": 0.001,
      "type": "range"
    },
    {
      "name": "viscosity",
      "label": "Viscosity",
      "min": 0.0001,
      "max": 0.02,
      "step": 0.0001,
      "type": "range"
    },
    {
      "name": "bulkVx",
      "label": "Mean flow (→)",
      "min": 0,
      "max": 4,
      "step": 0.05,
      "type": "range"
    },
    {
      "name": "force",
      "label": "Inlet Force",
      "min": 0,
      "max": 4,
      "step": 0.01,
      "type": "range"
    },
    {
      "name": "dyeDissipation",
      "label": "Dye Dissipation",
      "min": 0,
      "max": 0.02,
      "step": 0.0001,
      "type": "range"
    },
    {
      "name": "_restart",
      "label": "Restart",
      "action": "restart",
      "type": "button"
    }
  ],
  "metadata": {
    "gridWidth": 128,
    "gridHeight": 96,
    "time": 0,
    "dt": 0.02,
    "viscosity": 0.0015,
    "bulkVx": 1.5,
    "force": 1.8,
    "dyeDissipation": 0.002
  },
  "resources": {
    "Params": {
      "type": "uniform",
      "fields": {
        "gridWidth": "f32",
        "gridHeight": "f32",
        "time": "f32",
        "dt": "f32",
        "viscosity": "f32",
        "bulkVx": "f32",
        "force": "f32",
        "dyeDissipation": "f32"
      }
    },
    "Camera": {
      "type": "uniform",
      "fields": {
        "viewProjection": "mat4x4<f32>",
        "view": "mat4x4<f32>"
      }
    },
    "Velocity": {
      "type": "storage",
      "access": "read_write",
      "format": "vec4<f32>",
      "count": "$metadata.gridWidth * $metadata.gridHeight",
      "bufferCount": 2
    },
    "Dye": {
      "type": "storage",
      "access": "read_write",
      "format": "f32",
      "count": "$metadata.gridWidth * $metadata.gridHeight",
      "bufferCount": 2
    },
    "SurfaceData": {
      "type": "storage",
      "access": "read_write",
      "format": "vec4<f32>",
      "count": "$metadata.gridWidth * $metadata.gridHeight * 2"
    }
  },
  "nodes": [
    {
      "id": "init_fields",
      "type": "compute",
      "shader": "init_fields",
      "dispatch": {
        "type": "direct",
        "workgroups": [
          "$metadata.gridWidth / 8 + 1",
          "$metadata.gridHeight / 8 + 1",
          1
        ]
      },
      "bindings": [
        {
          "binding": 0,
          "resource": "Params"
        },
        {
          "binding": 1,
          "resource": "Velocity",
          "historyLevel": 0,
          "varName": "velOut",
          "access": "read_write"
        },
        {
          "binding": 2,
          "resource": "Dye",
          "historyLevel": 0,
          "varName": "dyeOut",
          "access": "read_write"
        }
      ]
    },
    {
      "id": "step_velocity",
      "type": "compute",
      "shader": "step_velocity",
      "dispatch": {
        "type": "direct",
        "workgroups": [
          "$metadata.gridWidth / 8 + 1",
          "$metadata.gridHeight / 8 + 1",
          1
        ]
      },
      "bindings": [
        {
          "binding": 0,
          "resource": "Params"
        },
        {
          "binding": 1,
          "resource": "Velocity",
          "historyLevel": 1,
          "varName": "velIn"
        },
        {
          "binding": 2,
          "resource": "Velocity",
          "historyLevel": 0,
          "varName": "velOut",
          "access": "read_write"
        }
      ]
    },
    {
      "id": "step_dye",
      "type": "compute",
      "shader": "step_dye",
      "dispatch": {
        "type": "direct",
        "workgroups": [
          "$metadata.gridWidth / 8 + 1",
          "$metadata.gridHeight / 8 + 1",
          1
        ]
      },
      "bindings": [
        {
          "binding": 0,
          "resource": "Params"
        },
        {
          "binding": 1,
          "resource": "Velocity",
          "historyLevel": 0,
          "varName": "velIn"
        },
        {
          "binding": 2,
          "resource": "Dye",
          "historyLevel": 1,
          "varName": "dyeIn"
        },
        {
          "binding": 3,
          "resource": "Dye",
          "historyLevel": 0,
          "varName": "dyeOut",
          "access": "read_write"
        }
      ]
    },
    {
      "id": "build_surface",
      "type": "compute",
      "shader": "build_surface",
      "dispatch": {
        "type": "direct",
        "workgroups": [
          "$metadata.gridWidth / 8 + 1",
          "$metadata.gridHeight / 8 + 1",
          1
        ]
      },
      "bindings": [
        {
          "binding": 0,
          "resource": "Params"
        },
        {
          "binding": 1,
          "resource": "Dye",
          "historyLevel": 0,
          "varName": "dyeIn"
        },
        {
          "binding": 2,
          "resource": "SurfaceData",
          "access": "read_write"
        }
      ]
    },
    {
      "id": "render_surface",
      "type": "render",
      "shader": "render_surface",
      "topology": "triangle-list",
      "depthTest": true,
      "draw": {
        "type": "direct",
        "vertexCount": "($metadata.gridWidth - 1) * ($metadata.gridHeight - 1) * 6"
      },
      "bindings": [
        {
          "binding": 0,
          "resource": "Params"
        },
        {
          "binding": 1,
          "resource": "Camera"
        },
        {
          "binding": 2,
          "resource": "SurfaceData",
          "access": "read"
        }
      ]
    }
  ]
}
